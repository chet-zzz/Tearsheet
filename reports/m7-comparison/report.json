{
  "root": "page",
  "elements": {
    "page": {
      "type": "Page",
      "props": {
        "title": "Magnificent 7 财务对比",
        "subtitle": "估值 · 增长 · 质量(ROIC) · 资本配置 · 现金流 · 单位：十亿美元 · 财报源 SEC 10-K，估值/市值 as-of 2026-06-08 (stockanalysis.com)",
        "updatedAt": "2026-06-08"
      },
      "children": ["sec-kpi", "sec-valuation", "sec-position", "sec-allocation", "sec-cash", "sec-insight"]
    },

    "sec-kpi": {
      "type": "Section",
      "props": { "title": "M7 概览", "description": "七家合计（各自最新财年）· 单位十亿美元" },
      "children": ["kpi-bar"]
    },
    "kpi-bar": {
      "type": "SummaryBar",
      "props": {
        "title": "M7 合计盘子",
        "items": [
          { "label": "合计营收", "unit": "十亿$", "value": { "$computed": "sum", "args": { "rows": { "$state": "/datasets/m7/rows" }, "field": "revenue" } } },
          { "label": "合计净利润", "unit": "十亿$", "value": { "$computed": "sum", "args": { "rows": { "$state": "/datasets/m7/rows" }, "field": "net_income" } } },
          { "label": "合计自由现金流", "unit": "十亿$", "value": { "$computed": "sum", "args": { "rows": { "$state": "/datasets/m7/rows" }, "field": "fcf" } } },
          { "label": "合计资本开支", "unit": "十亿$", "value": { "$computed": "sum", "args": { "rows": { "$state": "/datasets/m7/rows" }, "field": "capex" } } },
          { "label": "合计股东回报", "unit": "十亿$", "value": { "$computed": "sum", "args": { "rows": { "$state": "/datasets/m7/rows" }, "field": "shareholder_return" } } }
        ]
      },
      "children": []
    },

    "sec-valuation": {
      "type": "Section",
      "props": { "title": "估值与质量全景", "description": "谁贵 / 谁优质 / 谁增长——市值条编码规模，FCF收益率/增速/ROIC/Rule40 色阶定强弱，底部为 M7 中位基准" },
      "children": ["comp-table"]
    },
    "comp-table": {
      "type": "DataTable",
      "props": {
        "pageSize": 0,
        "summaryRow": true,
        "summaryAgg": "median",
        "summaryLabel": "M7 中位",
        "columnGroups": [
          { "span": 1 },
          { "label": "规模", "span": 1 },
          { "label": "估值（越低越便宜）", "span": 3 },
          { "label": "增长与质量（越高越好）", "span": 3 }
        ],
        "data": { "$computed": "sortBy", "args": { "rows": { "$state": "/datasets/m7/rows" }, "field": "market_cap", "dir": "desc" } },
        "columns": [
          { "key": "company", "label": "公司" },
          { "key": "market_cap", "label": "市值 (十亿$)", "format": "number", "mode": "bar" },
          { "key": "pe_ttm", "label": "P/E", "format": "number", "digits": 1, "align": "right" },
          { "key": "ev_ebitda", "label": "EV/EBITDA", "format": "number", "digits": 1, "align": "right" },
          { "key": "fcf_yield", "label": "FCF收益率", "format": "percent", "digits": 1, "mode": "heat" },
          { "key": "rev_growth", "label": "营收增速", "format": "percent", "digits": 1, "mode": "heat" },
          { "key": "roic", "label": "ROIC", "format": "percent", "digits": 1, "mode": "heat" },
          { "key": "rule_of_40", "label": "Rule of 40", "format": "number", "digits": 0, "mode": "heat" }
        ]
      },
      "children": []
    },

    "sec-position": {
      "type": "Section",
      "props": { "title": "增长 × 质量定位与达标", "description": "谁在「双高」优势区、谁过 Rule of 40 及格线" },
      "children": ["grid-position"]
    },
    "grid-position": {
      "type": "Grid",
      "props": { "gap": "sm", "spans": [6, 6] },
      "children": ["scatter-gq", "rule40-bar"]
    },
    "scatter-gq": {
      "type": "ScatterChart",
      "props": {
        "title": "增长 × 质量矩阵",
        "subtitle": "x=营收增速% · y=ROIC% · 气泡=市值 · 十字为均值，右上=高增长高回报",
        "xKey": "rev_growth", "yKey": "roic", "sizeKey": "market_cap", "nameKey": "company",
        "xLabel": "营收增速%", "yLabel": "ROIC%",
        "quadrantMean": true,
        "valueFormat": "number", "height": 300,
        "data": { "$state": "/datasets/m7/rows" }
      },
      "children": []
    },
    "rule40-bar": {
      "type": "BarChart",
      "props": {
        "title": "Rule of 40 达标排行",
        "subtitle": "营收增速 + 经营利润率，>40 为健康（软件/科技通用门槛）",
        "xKey": "company",
        "sort": "desc",
        "showValues": true,
        "valueFormat": "number",
        "height": 300,
        "refLines": [{ "y": 40, "label": "及格线 40", "tone": "warning" }],
        "series": [{ "key": "rule_of_40", "label": "Rule of 40" }],
        "data": { "$state": "/datasets/m7/rows" }
      },
      "children": []
    },

    "sec-allocation": {
      "type": "Section",
      "props": { "title": "赚钱与花钱", "description": "钱主要花到哪、现金又如何在「再投资 / 回报股东」间分配" },
      "children": ["grid-allocation"]
    },
    "grid-allocation": {
      "type": "Grid",
      "props": { "gap": "sm", "spans": [6, 6] },
      "children": ["cost-structure", "capital-alloc"]
    },
    "cost-structure": {
      "type": "BarChart",
      "props": {
        "title": "经营成本去哪：每 100 元收入的去向",
        "subtitle": "营业成本 / 研发(技术) / 销售管理(含亚马逊履约) / 经营利润，按经营利润率排序",
        "xKey": "company",
        "stack100": true,
        "showValues": true,
        "valueFormat": "number",
        "height": 300,
        "series": [
          { "key": "cogs", "label": "营业成本" },
          { "key": "rd", "label": "研发/技术" },
          { "key": "sga", "label": "销售管理/运营" },
          { "key": "profit", "label": "经营利润" }
        ],
        "data": { "$computed": "sortBy", "args": { "rows": { "$state": "/datasets/m7/rows" }, "field": "op_margin", "dir": "asc" } }
      },
      "children": []
    },
    "capital-alloc": {
      "type": "BarChart",
      "props": {
        "title": "资本去向：现金花在哪 (十亿$)",
        "subtitle": "再投资(资本开支+研发) vs 回报股东(回购+分红)，按营收排序",
        "xKey": "company",
        "stacked": true,
        "valueFormat": "number",
        "height": 300,
        "series": [
          { "key": "capex", "label": "资本开支" },
          { "key": "rd", "label": "研发" },
          { "key": "buyback", "label": "股票回购" },
          { "key": "dividend", "label": "分红" }
        ],
        "data": { "$computed": "sortBy", "args": { "rows": { "$state": "/datasets/m7/rows" }, "field": "revenue", "dir": "desc" } }
      },
      "children": []
    },

    "sec-cash": {
      "type": "Section",
      "props": { "title": "现金含金量与 AI 投入", "description": "利润是否变现金、资本开支强度吞噬多少自由现金流" },
      "children": ["grid-cash"]
    },
    "grid-cash": {
      "type": "Grid",
      "props": { "gap": "sm", "spans": [6, 6] },
      "children": ["cfo-ni", "fcf-capex"]
    },
    "cfo-ni": {
      "type": "DumbbellChart",
      "props": {
        "title": "经营现金流 vs 净利润",
        "subtitle": "现金流 > 净利 = 盈利含金量高（十亿美元）",
        "labelKey": "company", "startKey": "net_income", "endKey": "cfo",
        "startLabel": "净利润", "endLabel": "经营现金流", "valueFormat": "number",
        "data": { "$computed": "sortBy", "args": { "rows": { "$state": "/datasets/m7/rows" }, "field": "cfo", "dir": "desc" } }
      },
      "children": []
    },
    "fcf-capex": {
      "type": "BarChart",
      "props": {
        "title": "自由现金流率 vs 资本开支率：AI 军备竞赛吞噬现金",
        "subtitle": "资本开支占营收越高，留存的自由现金流越薄（%）",
        "xKey": "company",
        "valueFormat": "percent",
        "showValues": true,
        "height": 300,
        "series": [
          { "key": "fcf_margin", "label": "自由现金流率%" },
          { "key": "capex_intensity", "label": "资本开支率%" }
        ],
        "data": { "$computed": "sortBy", "args": { "rows": { "$state": "/datasets/m7/rows" }, "field": "capex_intensity", "dir": "desc" } }
      },
      "children": []
    },

    "sec-insight": {
      "type": "Section",
      "props": { "title": "投资结论" },
      "children": ["grid-insight"]
    },
    "grid-insight": {
      "type": "Grid",
      "props": { "gap": "sm", "spans": [3, 3, 3, 3] },
      "children": ["insight-val", "insight-quality", "insight-capital", "insight-ai"]
    },
    "insight-val": {
      "type": "Insight",
      "props": {
        "title": "估值分化：贵得有理 vs 贵得离谱",
        "content": "特斯拉 P/E 380×、EV/EBITDA 130× 却营收 −2.9%、ROIC 仅 6%，估值与基本面严重背离；Meta（P/E 21.6）、微软（24.8）相对最便宜，且 Rule of 40 分别 64 / 61，是「便宜且优质」一档。",
        "tone": "warning"
      },
      "children": []
    },
    "insight-quality": {
      "type": "Insight",
      "props": {
        "title": "质量看护城河：ROIC 两极分化",
        "content": "苹果 ROIC 104%、英伟达 105% 遥遥领先（轻资产 + 高毛利 + 巨额回购压缩权益）；亚马逊 13%、特斯拉 6% 垫底（重资产、低利润）。ROIC 长期 > 资本成本，才是真正创造价值的复利机器。",
        "tone": "positive"
      },
      "children": []
    },
    "insight-capital": {
      "type": "Insight",
      "props": {
        "title": "资本配置：现金牛 vs 再投资狂",
        "content": "苹果一年回购 $967 亿、股东回报合计 $1,121 亿，是典型现金牛；亚马逊、特斯拉 0 回购 0 分红，把现金全部砸回再投资（亚马逊资本开支 $1,318 亿 + 研发 $1,085 亿）。配置取向天差地别。",
        "tone": "neutral"
      },
      "children": []
    },
    "insight-ai": {
      "type": "Insight",
      "props": {
        "title": "AI 投入与增长质量",
        "content": "英伟达 Rule of 40 高达 126 一骑绝尘（增速 65% + 利润率 60%）；Meta（35%）、微软（23%）、谷歌（23%）把两成以上营收砸进 AI 资本开支；只有亚马逊（24）、特斯拉（2）未过 Rule of 40 及格线。",
        "tone": "neutral"
      },
      "children": []
    }
  }
}
