{
  "root": "page",
  "elements": {
    "page": {
      "type": "Page",
      "props": {
        "title": "Magnificent 7 财务对比",
        "subtitle": "估值 · 增长 · 质量(ROIC) · 资本配置 · 现金流 · 单位：十亿美元 · 财报源 SEC 10-K，估值/前瞻一致预期 as-of 2026-06-08 (stockanalysis.com)",
        "updatedAt": "2026-06-08"
      },
      "children": ["sec-kpi", "sec-valuation", "sec-position", "sec-trend", "sec-capital", "sec-insight"]
    },

    "sec-kpi": {
      "type": "Section",
      "props": { "title": "M7 概览", "description": "七家合计（各自最新财年）· 单位十亿美元" },
      "children": ["kpi-bar"]
    },
    "kpi-bar": {
      "type": "SummaryBar",
      "props": {
        "title": "M7 合计盘子",
        "items": [
          { "label": "合计营收", "unit": "十亿$", "value": { "$computed": "sum", "args": { "rows": { "$state": "/datasets/m7/rows" }, "field": "revenue" } } },
          { "label": "合计净利润", "unit": "十亿$", "value": { "$computed": "sum", "args": { "rows": { "$state": "/datasets/m7/rows" }, "field": "net_income" } } },
          { "label": "合计自由现金流", "unit": "十亿$", "value": { "$computed": "sum", "args": { "rows": { "$state": "/datasets/m7/rows" }, "field": "fcf" } } },
          { "label": "合计资本开支", "unit": "十亿$", "value": { "$computed": "sum", "args": { "rows": { "$state": "/datasets/m7/rows" }, "field": "capex" } } },
          { "label": "合计股东回报", "unit": "十亿$", "value": { "$computed": "sum", "args": { "rows": { "$state": "/datasets/m7/rows" }, "field": "shareholder_return" } } }
        ]
      },
      "children": []
    },

    "sec-valuation": {
      "type": "Section",
      "props": { "title": "估值与质量全景", "description": "一张表把所有单指标排名「合并」：市值条编码规模，TTM 与前瞻 P/E 并看，FCF收益率/增速/ROIC/Rule40 色阶定强弱，底部为 M7 中位基准" },
      "children": ["comp-table"]
    },
    "comp-table": {
      "type": "DataTable",
      "props": {
        "pageSize": 0,
        "summaryRow": true,
        "summaryAgg": "median",
        "summaryLabel": "M7 中位",
        "columnGroups": [
          { "span": 1 },
          { "label": "规模", "span": 1 },
          { "label": "估值（越低越便宜）", "span": 4 },
          { "label": "增长与质量（越高越好）", "span": 4 }
        ],
        "data": { "$computed": "sortBy", "args": { "rows": { "$state": "/datasets/m7/rows" }, "field": "market_cap", "dir": "desc" } },
        "columns": [
          { "key": "company", "label": "公司" },
          { "key": "market_cap", "label": "市值 (十亿$)", "format": "number", "mode": "bar" },
          { "key": "pe_ttm", "label": "P/E", "format": "number", "digits": 1, "align": "right" },
          { "key": "fwd_pe", "label": "前瞻 P/E", "format": "number", "digits": 1, "align": "right" },
          { "key": "ev_ebitda", "label": "EV/EBITDA", "format": "number", "digits": 1, "align": "right" },
          { "key": "fcf_yield", "label": "FCF收益率", "format": "percent", "digits": 1, "mode": "heat" },
          { "key": "rev_growth", "label": "营收增速", "format": "percent", "digits": 1, "mode": "heat" },
          { "key": "fwd_rev_growth", "label": "前瞻增速", "format": "percent", "digits": 1, "mode": "heat" },
          { "key": "roic", "label": "ROIC", "format": "percent", "digits": 1, "mode": "heat" },
          { "key": "rule_of_40", "label": "Rule of 40", "format": "number", "digits": 0, "mode": "heat" }
        ]
      },
      "children": []
    },

    "sec-position": {
      "type": "Section",
      "props": { "title": "增长 × 质量定位与达标", "description": "散点看「在不在双高优势区」，子弹看「过没过 Rule of 40 门槛」" },
      "children": ["grid-position"]
    },
    "grid-position": {
      "type": "Grid",
      "props": { "gap": "sm", "spans": [7, 5] },
      "children": ["scatter-gq", "rule40-bullet"]
    },
    "scatter-gq": {
      "type": "ScatterChart",
      "props": {
        "title": "增长 × 质量矩阵",
        "subtitle": "x=营收增速% · y=ROIC% · 气泡=市值 · 十字为均值，右上=高增长高回报",
        "xKey": "rev_growth", "yKey": "roic", "sizeKey": "market_cap", "nameKey": "company",
        "xLabel": "营收增速%", "yLabel": "ROIC%",
        "quadrantMean": true,
        "percentAxes": true,
        "valueFormat": "number", "height": 320,
        "data": { "$state": "/datasets/m7/rows" }
      },
      "children": []
    },
    "rule40-bullet": {
      "type": "BulletChart",
      "props": {
        "title": "Rule of 40 达标",
        "subtitle": "营收增速 + 经营利润率，对标 40 门槛（刻度线）",
        "labelKey": "company", "valueKey": "rule_of_40", "targetKey": "r40_target",
        "valueFormat": "number",
        "data": { "$computed": "sortBy", "args": { "rows": { "$state": "/datasets/m7/rows" }, "field": "rule_of_40", "dir": "desc" } }
      },
      "children": []
    },

    "sec-trend": {
      "type": "Section",
      "props": { "title": "成本结构与增长趋势", "description": "钱花到哪、增长在加速还是减速" },
      "children": ["grid-trend"]
    },
    "grid-trend": {
      "type": "Grid",
      "props": { "gap": "sm", "spans": [6, 6] },
      "children": ["cost-structure", "growth-slope"]
    },
    "cost-structure": {
      "type": "BarChart",
      "props": {
        "title": "经营成本去哪：每 100 元收入的去向",
        "subtitle": "营业成本 / 研发(技术) / 销售管理(含亚马逊履约) / 经营利润，按经营利润率排序",
        "xKey": "company",
        "stack100": true,
        "showValues": true,
        "valueFormat": "number",
        "height": 300,
        "series": [
          { "key": "cogs", "label": "营业成本" },
          { "key": "rd", "label": "研发/技术", "color": 2 },
          { "key": "sga", "label": "销售管理/运营" },
          { "key": "profit", "label": "经营利润" }
        ],
        "data": { "$computed": "sortBy", "args": { "rows": { "$state": "/datasets/m7/rows" }, "field": "op_margin", "dir": "asc" } }
      },
      "children": []
    },
    "growth-slope": {
      "type": "SlopeChart",
      "props": {
        "title": "营收增速：TTM → 前瞻一致预期",
        "subtitle": "谁在加速、谁在减速（特斯拉缺前瞻一致预期，未纳入）",
        "labelKey": "company", "startKey": "rev_growth", "endKey": "fwd_rev_growth",
        "startLabel": "TTM", "endLabel": "前瞻", "valueFormat": "percent", "height": 300,
        "data": { "$computed": "filter", "args": { "rows": { "$state": "/datasets/m7/rows" }, "field": "company", "op": "ne", "value": "特斯拉" } }
      },
      "children": []
    },

    "sec-capital": {
      "type": "Section",
      "props": { "title": "资本去向与 AI 投入", "description": "AI 资本开支的绝对额与强度、现金在「再投资 / 回报股东」间如何分配" },
      "children": ["grid-capital"]
    },
    "grid-capital": {
      "type": "Grid",
      "props": { "gap": "sm", "spans": [6, 6] },
      "children": ["capex-combo", "capital-alloc"]
    },
    "capex-combo": {
      "type": "ComboChart",
      "props": {
        "title": "AI 资本开支：绝对额 vs 强度",
        "subtitle": "柱=资本开支(十亿$，左轴) · 线=占营收%(右轴) — 亚马逊额大、Meta 强度最高",
        "xKey": "company",
        "secondAxis": true,
        "valueFormat": "number",
        "height": 300,
        "bars": [{ "key": "capex", "label": "资本开支 (十亿$)", "color": 5 }],
        "lines": [{ "key": "capex_intensity", "label": "资本开支强度%" }],
        "data": { "$computed": "sortBy", "args": { "rows": { "$state": "/datasets/m7/rows" }, "field": "capex", "dir": "desc" } }
      },
      "children": []
    },
    "capital-alloc": {
      "type": "BarChart",
      "props": {
        "title": "资本去向：现金花在哪 (十亿$)",
        "subtitle": "再投资(资本开支+研发) vs 回报股东(回购+分红)，按营收排序",
        "xKey": "company",
        "stacked": true,
        "valueFormat": "number",
        "height": 300,
        "series": [
          { "key": "capex", "label": "资本开支", "color": 5 },
          { "key": "rd", "label": "研发", "color": 2 },
          { "key": "buyback", "label": "股票回购" },
          { "key": "dividend", "label": "分红" }
        ],
        "data": { "$computed": "sortBy", "args": { "rows": { "$state": "/datasets/m7/rows" }, "field": "revenue", "dir": "desc" } }
      },
      "children": []
    },

    "sec-insight": {
      "type": "Section",
      "props": { "title": "投资结论" },
      "children": ["grid-insight"]
    },
    "grid-insight": {
      "type": "Grid",
      "props": { "gap": "sm", "spans": [3, 3, 3, 3] },
      "children": ["insight-val", "insight-quality", "insight-sbc", "insight-ai"]
    },
    "insight-val": {
      "type": "Insight",
      "props": {
        "title": "估值分化：贵得有理 vs 离谱",
        "content": "特斯拉 P/E 380×（前瞻仍 181×）却营收 −2.9%、ROIC 6%，估值与基本面严重背离；Meta（前瞻 P/E 18×）、微软（22×）相对最便宜，且 Rule of 40 达 60+，是「便宜又优质」一档；英伟达前瞻 P/E 仅 21×，增长消化了估值。",
        "tone": "warning"
      },
      "children": []
    },
    "insight-quality": {
      "type": "Insight",
      "props": {
        "title": "质量看护城河：ROIC 两极分化",
        "content": "苹果 ROIC 104%、英伟达 105% 遥遥领先（轻资产 + 高毛利 + 巨额回购压缩权益）；亚马逊 13%、特斯拉 6% 垫底（重资产、低利润）。ROIC 长期 > 资本成本，才是真正创造价值的复利机器。",
        "tone": "positive"
      },
      "children": []
    },
    "insight-sbc": {
      "type": "Insight",
      "props": {
        "title": "别只看 FCF：股权激励在「注水」",
        "content": "SBC（不花现金的股权激励）被加回经营现金流，撑高了自由现金流。扣掉 SBC 后，亚马逊 FCF 从 +$77 亿转为 −$118 亿（SBC 高达 $195 亿）、Meta/谷歌也被显著稀释；英伟达、苹果 SBC 占比低，FCF 更「干净」。",
        "tone": "warning"
      },
      "children": []
    },
    "insight-ai": {
      "type": "Insight",
      "props": {
        "title": "增长质量与 AI 投入",
        "content": "英伟达增速虽从 65% 放缓到前瞻 40%，Rule of 40 仍高达 126 一骑绝尘；Meta（强度 35%）、微软（23%）、谷歌（23%）把两成以上营收砸进 AI 资本开支；只有亚马逊（24）、特斯拉（2）未过 Rule of 40 及格线。",
        "tone": "neutral"
      },
      "children": []
    }
  }
}
